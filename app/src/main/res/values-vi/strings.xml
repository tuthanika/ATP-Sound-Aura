    <string name="play_in_background_setting_title">Phát trong nền</string>
    <string name="play_in_background_setting_description">Duy trì phát khi chạy nền</string>
    <string name="play_in_background_explanation">Khi bật phát trong nền, SoundAura sẽ thay đổi hành vi như sau:</string>
    <string name="play_in_background_explanation_bullet_1">Hiển thị điều khiển phát trong thông báo thường thay vì khu vực media controls</string>
    <string name="play_in_background_explanation_bullet_2">Giúp phát tiếp tục khi mở app khác</string>
    <string name="play_in_background_explanation_bullet_3">Bỏ qua nút media phần cứng, ví dụ nút play pause trên tai nghe, trừ khi app đang mở</string>
    <string name="play_in_background_explanation_bullet_4">Không tự tạm dừng khi có cuộc gọi, trừ khi bật tùy chọn tạm dừng khi có cuộc gọi và đã cấp quyền đọc trạng thái điện thoại</string>

    
    <string name="request_notification_permission_title">Cần quyền thông báo</string>
    <string name="request_notification_permission_explanation_p1">Khi bật phát trong nền, SoundAura cần thông báo thường để hiện điều khiển phát. Để làm được điều này cần quyền gửi thông báo.</string>
    <string name="request_notification_permission_explanation_p2">Nếu bạn không muốn cấp quyền hoặc muốn tiết kiệm không gian thông báo, bạn có thể %1$s.</string>
    <string name="tile_tutorial_link_text">điều khiển SoundAura bằng tile cài đặt nhanh</string>

    
